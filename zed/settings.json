// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "colorize_brackets": false,
  "indent_guides": {
    "background_coloring": "disabled",
  },
  "auto_signature_help": false,
  "sticky_scroll": {
    "enabled": true,
  },
  "double_click_in_multibuffer": "select",
  "close_on_file_delete": true,
  "file_finder": {
    "modal_max_width": "small",
  },
  "search": {
    "center_on_match": true,
  },
  "active_pane_modifiers": {
    "inactive_opacity": 1.0,
  },
  "use_system_window_tabs": false,
  "centered_layout": {
    "left_padding": 0.2,
  },
  "bottom_dock_layout": "contained",
  "title_bar": {
    "show_menus": false,
    "show_branch_icon": false,
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
    },
  },
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "agent": {
    "always_allow_tool_actions": true,
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "model_parameters": [],
  },
  "vim": {
    "use_system_clipboard": "on_yank",
  },
  "show_edit_predictions": false,
  "vim_mode": true,
  "theme": "Zedokai Darker (Filter Ristretto)",
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "ui_font_size": 14,
  "buffer_font_size": 12.0,
  "buffer_font_family": null,
  "buffer_font_features": {
    "calt": false,
    "liga": false,
    "cv02": false,
  },
  "tab_size": 2,
  "journal": {
    "path": "~",
    "hour_format": "hour24",
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "env": {
      "GIT_EDITOR": "zed --wait",
    },
  },
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": false,
    "show_parameter_hints": false,
    "show_other_hints": false,
  },
  "preferred_line_length": 100,
  "collaboration_panel": {
    "button": false,
  },
  "notification_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": true,
  },
  "file_scan_exclusions": ["**/.bundle", "**/vendor/bundle", "**/.idea"],
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "left_neighbour",
    "show_close_button": "hidden",
  },
  "toolbar": {
    "code_actions": false,
    "quick_actions": false,
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": false,
  },
  "seed_search_query_from_cursor": "selection",
  "use_smartcase_search": true,
  "extend_comment_on_newline": false,
  "languages": {
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "wrap_guides": [100],
      "format_on_save": "on",
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "wrap_guides": [100],
      "format_on_save": "on",
    },
    "TSX": {
      "tasks": {
        "prefer_lsp": false,
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
      "wrap_guides": [100],
      "format_on_save": "on",
    },
    "SCSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true,
      },
    },
    "Git Commit": {
      "wrap_guides": [50, 72],
      "preferred_line_length": 72,
      "show_completions_on_input": false,
    },
    "YAML": {
      "format_on_save": "off",
    },
  },
  "file_types": {
    "SCSS": ["*.SCSS"], // Were still being treated as .css files
    "Terraform": ["*.tofu"],
    "HTML": ["*.svg"],
  },
  "lsp": {
    "json-language-server": {
      "settings": {
        "json": {
          "keyOrdering": true,
          "schemas": [
            {
              "fileMatch": ["nodemon.json"],
              "url": "https://json.schemastore.org/nodemon.json",
            },
          ],
        },
      },
    },
    "yaml-language-server": {
      "settings": {
        "schemas": {
          "https://raw.githubusercontent.com/nexlabstudio/maestro-workbench/dev/schema/schema.v0.json": [
            "e2e/*.yaml",
            "e2e/*.yml",
          ],
          "https://gitlab.com/gitlab-org/gitlab/-/raw/master/app/assets/javascripts/editor/schema/ci.json": ".gitlab-ci.yml",
        },
      },
    },
  },
}
